@model IEnumerable<MiniCMS.Web.Models.Article>

@{
    ViewData["Title"] = "Articles";
}

<div class="container py-4">
    <h1 class="h3 mb-3">Articles</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info mb-0">No articles found.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var a in Model)
            {
                <a asp-controller="Articles"
                   asp-action="Details"
                   asp-route-id="@a.Id"
                   class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">@a.Title</h5>
                        <small class="text-muted">Updated @a.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                    <small class="text-muted">Created @a.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                </a>
            }
        </div>
    }
</div>